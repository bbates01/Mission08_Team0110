@model IEnumerable<Mission08_Team0110.Models.TaskItem>

<h1 class="text-center my-4">Task Quadrants</h1>

<div class="container">
    <div class="row">
        <div class="col-6 border p-3">
            <h3>Quadrant 1 - Important / Urgent</h3>
            @foreach (var task in Model.Where(t => t.Quadrant == 1))
            {
                <div class="card mb-2 p-2">
                    <strong>@task.TaskName</strong>
                    <p>Due: @task.DueDate?.ToShortDateString()</p>
                    <p>Category: @task.Category?.Name</p>
                    <a asp-action="Edit" asp-route-id="@task.TaskId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-sm btn-danger">Delete</a>
                    <a asp-action="MarkComplete" asp-route-id="@task.TaskId" class="btn btn-sm btn-success">Mark Complete</a>
                </div>
            }
        </div>
        <div class="col-6 border p-3">
            <h3>Quadrant 2 - Important / Not Urgent</h3>
            @foreach (var task in Model.Where(t => t.Quadrant == 2))
            {
                <div class="card mb-2 p-2">
                    <strong>@task.TaskName</strong>
                    <p>Due: @task.DueDate?.ToShortDateString()</p>
                    <p>Category: @task.Category?.Name</p>
                    <a asp-action="Edit" asp-route-id="@task.TaskId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-sm btn-danger">Delete</a>
                    <a asp-action="MarkComplete" asp-route-id="@task.TaskId" class="btn btn-sm btn-success">Mark Complete</a>
                </div>
            }
        </div>
    </div>
    <div class="row">
        <div class="col-6 border p-3">
            <h3>Quadrant 3 - Not Important / Urgent</h3>
            @foreach (var task in Model.Where(t => t.Quadrant == 3))
            {
                <div class="card mb-2 p-2">
                    <strong>@task.TaskName</strong>
                    <p>Due: @task.DueDate?.ToShortDateString()</p>
                    <p>Category: @task.Category?.Name</p>
                    <a asp-action="Edit" asp-route-id="@task.TaskId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-sm btn-danger">Delete</a>
                    <a asp-action="MarkComplete" asp-route-id="@task.TaskId" class="btn btn-sm btn-success">Mark Complete</a>
                </div>
            }
        </div>
        <div class="col-6 border p-3">
            <h3>Quadrant 4 - Not Important / Not Urgent</h3>
            @foreach (var task in Model.Where(t => t.Quadrant == 4))
            {
                <div class="card mb-2 p-2">
                    <strong>@task.TaskName</strong>
                    <p>Due: @task.DueDate?.ToShortDateString()</p>
                    <p>Category: @task.Category?.Name</p>
                    <a asp-action="Edit" asp-route-id="@task.TaskId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-sm btn-danger">Delete</a>
                    <a asp-action="MarkComplete" asp-route-id="@task.TaskId" class="btn btn-sm btn-success">Mark Complete</a>
                </div>
            }
        </div>
    </div>
</div>